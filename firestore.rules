rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net - default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Zero-Trust Primitive Definitions
    function isSignedIn() {
      return request.auth != null;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Entity Schema Validation Blueprint: User Document Structure
    function isValidUser(data) {
      return (
        data.keys().hasAll([
          'username', 'email', 'level', 'xp', 'totalScore', 
          'highestScore', 'longestCombo', 'gamesPlayed', 
          'achievements', 'createdAt', 'lastLogin'
        ]) 
        && data.keys().size() == 11
        && data.username is string && data.username.size() >= 1 && data.username.size() <= 40
        && data.email is string && data.email.size() >= 0 && data.email.size() <= 100
        && data.level is int && data.level >= 1 && data.level <= 100
        && data.xp is int && data.xp >= 0 && data.xp <= 5000000
        && data.totalScore is int && data.totalScore >= 0
        && data.highestScore is int && data.highestScore >= 0
        && data.longestCombo is int && data.longestCombo >= 0
        && data.gamesPlayed is int && data.gamesPlayed >= 0
        && data.achievements is list && data.achievements.size() <= 100
        && data.createdAt is timestamp
        && data.lastLogin is timestamp
      ) || (
        data.keys().hasAll([
          'username', 'password', 'email', 'level', 'xp', 'totalScore', 
          'highestScore', 'longestCombo', 'gamesPlayed', 
          'achievements', 'createdAt', 'lastLogin'
        ]) 
        && data.keys().size() == 12
        && data.username is string && data.username.size() >= 1 && data.username.size() <= 40
        && data.password is string && data.password.size() == 64
        && data.email is string && data.email.size() >= 0 && data.email.size() <= 100
        && data.level is int && data.level >= 1 && data.level <= 100
        && data.xp is int && data.xp >= 0 && data.xp <= 5000000
        && data.totalScore is int && data.totalScore >= 0
        && data.highestScore is int && data.highestScore >= 0
        && data.longestCombo is int && data.longestCombo >= 0
        && data.gamesPlayed is int && data.gamesPlayed >= 0
        && data.achievements is list && data.achievements.size() <= 100
        && data.createdAt is timestamp
        && data.lastLogin is timestamp
      );
    }

    // Entity Schema Validation Blueprint: Leaderboard Entry Structure
    function isValidLeaderboardEntry(data) {
      return data.keys().hasAll([
        'playerName', 'totalScore', 'averageDistance', 'level', 'createdAt'
      ])
      && data.keys().size() == 5
      && data.playerName is string && data.playerName.size() >= 1 && data.playerName.size() <= 40
      && data.totalScore is int && data.totalScore >= 0
      && (data.averageDistance is int || data.averageDistance is float)
      && data.level is int && data.level >= 1 && data.level <= 100
      && data.createdAt is timestamp;
    }

    // Collection Route: Users Profile Data Storage
    match /users/{userId} {
      allow read: if true;
      
      allow create: if isValidId(userId) 
        && isValidUser(incoming()) 
        && incoming().createdAt == request.time 
        && incoming().lastLogin == request.time;

      allow update: if isValidId(userId) 
        && isValidUser(incoming()) 
        && incoming().createdAt == existing().createdAt 
        && incoming().lastLogin == request.time
        && (
          (isSignedIn() && request.auth.uid == userId)
          || (existing().keys().hasAll(['password']) && existing().password == incoming().password)
        );

      allow delete: if false;
    }

    // Collection Route: Public Global Leaderboard High Scores
    match /leaderboard/{entryId} {
      allow read: if true; // Public listings accessible to all visitors
      
      allow create: if isValidId(entryId) 
        && isValidLeaderboardEntry(incoming()) 
        && incoming().createdAt == request.time;

      allow update, delete: if false; // Append-only immutable leaderboard entries
    }
  }
}
